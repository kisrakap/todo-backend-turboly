# Database Configuration (Neon PostgreSQL)
# Copy from Neon Dashboard → Connection string → Pooled connection
DATABASE_URL=postgresql://neondb_owner:password@ep-xxx-pooler.region.neon.tech/todo_db

# JWT Secret (generate random 32+ characters string)
JWT_SECRET=your_super_secret_jwt_key_here_minimum_32_characters_for_production

# Node Environment
NODE_ENV=production

# Port (Vercel akan auto-set ini)
PORT=3000

# Frontend URL untuk CORS (set ke URL frontend Vercel)
FRONTEND_URL=https://todo-frontend-xxxxx.vercel.app
