# Database Configuration (Railway akan auto set ini)
DATABASE_URL=postgresql://postgres:password@host:5432/database

# JWT Secret (buat string random minimal 32 karakter)
JWT_SECRET=your_super_secret_jwt_key_here_minimum_32_characters

# Node Environment
NODE_ENV=production

# Port (Railway akan auto set ini ke 3000 atau lebih)
PORT=3000

# Frontend URL untuk CORS (update dengan URL frontend Railway)
FRONTEND_URL=https://your-frontend-railway-domain.com
