# Database Configuration (Render PostgreSQL akan auto-set ini)
DATABASE_URL=postgresql://postgres:password@localhost:5432/todo_db

# JWT Secret (generate string random 32+ characters)
JWT_SECRET=your_super_secret_jwt_key_here_minimum_32_characters

# Node Environment
NODE_ENV=production

# Port (Render akan auto-set ini)
PORT=3000

# Frontend URL untuk CORS (update dengan URL frontend Render)
FRONTEND_URL=https://your-frontend-render-domain.onrender.com
